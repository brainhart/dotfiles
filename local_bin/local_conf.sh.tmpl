#!/bin/bash

{{ if .work_device }}
export FORGE_REPO_PATH="$HOME/code/source/monorepo"
alias forgectl="$FORGE_REPO_PATH/tools/forgectl/forgectl"
function refresh() {
	eval $(forgectl refresh)
}
export ATMOS_BASE_PATH="$FORGE_REPO_PATH/infra"
{{ end }}

ascii_random() {
        local len="${1:-64}" # default to 48 if no argument provided
        LC_ALL=C tr -dc 'A-Za-z0-9!@#$%^&*()_+=-' </dev/urandom | head -c "$len"
        echo
}

tee_copy() {
        local data

        # Read stdin fully into variable
        data="$(cat)"

        # Print to terminal
        printf "%s\n" "$data"

        # Copy to clipboard if available
        if command -v pbcopy &>/dev/null; then
                printf "%s" "$data" | pbcopy
        elif command -v xclip &>/dev/null; then
                printf "%s" "$data" | xclip -selection clipboard
        elif command -v wl-copy &>/dev/null; then
                printf "%s" "$data" | wl-copy
        fi
}

alias copy="tee_copy"
