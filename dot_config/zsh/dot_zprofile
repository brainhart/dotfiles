# macOS
if [[ "$OSTYPE" == darwin* ]]; then
  export XDG_DESKTOP_DIR=${XDG_DESKTOP_DIR:-$HOME/Desktop}
  export XDG_DOCUMENTS_DIR=${XDG_DOCUMENTS_DIR:-$HOME/Documents}
  export XDG_DOWNLOAD_DIR=${XDG_DOWNLOAD_DIR:-$HOME/Downloads}
  export XDG_MUSIC_DIR=${XDG_MUSIC_DIR:-$HOME/Music}
  export XDG_PICTURES_DIR=${XDG_PICTURES_DIR:-$HOME/Pictures}
  export XDG_VIDEOS_DIR=${XDG_VIDEOS_DIR:-$HOME/Videos}
  export XDG_PROJECTS_DIR=${XDG_PROJECTS_DIR:-$HOME/Projects}
  if [[ -d /opt/homebrew ]]; then
    export HOMEBREW_PREFIX=/opt/homebrew
  else
    export HOMEBREW_PREFIX=/usr/local
  fi
  export BROWSER='open'
fi

export VENV_DIR="$XDG_DATA_HOME/brian-venvs"

export EDITOR='nvim'
export VISUAL='nvim'
export PAGER='less'

export TZ="America/Los_Angeles"
export LANG="en_US.UTF-8"
export LANGUAGE="en"
export LC_ALL="en_US.UTF-8"

# Ensure path arrays do not contain duplicates
typeset -gU cdpath fpath mailpath path

export AQUA_GLOBAL_CONFIG=${XDG_CONFIG_HOME:-$HOME/.config}/aquaproj-aqua/aqua.yaml
export AQUA_POLICY_CONFIG=${XDG_CONFIG_HOME:-$HOME/.config}/aquaproj-aqua/policy.yaml

export VOLTA_HOME="$HOME/.volta"

export path=(
  ~/bin(N)
  ~/.local/bin
  ~/.local/share/aquaproj-aqua/bin
  $HOMEBREW_PREFIX/{bin,sbin}(N)
  # $VOLTA_HOME/bin:$PATH
  $VOLTA_HOME/bin
  /usr/local/{bin,sbin}(N)
  ~/.cargo/bin(N)
  $HOMEBREW_PREFIX/opt/postgresql@11/bin(N)
  ~/.local/
  $HOME/.krew/bin
  $HOME/go/bin
  /Applications/WezTerm.app/Contents/MacOS
  $path
)
if command -v fnm >/dev/null 2>&1; then
  aqua_root="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}"
  fnm_multishell="${FNM_MULTISHELL_PATH:-${XDG_RUNTIME_DIR:-$HOME/.xdg}/fnm_multishells}"
  if [[ -w "$aqua_root" && -w "${fnm_multishell%/*}" ]]; then
    mkdir -p "$fnm_multishell" 2>/dev/null
    if [[ -w "$fnm_multishell" ]]; then
      export FNM_MULTISHELL_PATH="$fnm_multishell"
      eval "$(fnm env --use-on-cd --version-file-strategy=recursive)"
    fi
  fi
fi

export SHELL_SESSIONS_DISABLE=1

# Added by OrbStack: command-line tools and integration
source ~/.orbstack/shell/init.zsh 2>/dev/null || :
